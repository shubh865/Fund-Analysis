{
  "name": "mutual-fund-analytics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server/server.js",
    "dev:web": "vite --config web/vite.config.js",
    "start": "node server/server.js",
    "import:daily-nav": "node scripts/import-daily-nav.js",
    "import:history": "node scripts/import-historical-archive.js",
    "seed:benchmark-defaults": "node scripts/seed-benchmark-defaults.js",
    "import:nifty-tri": "node scripts/import-nifty-tri.js",
    "refresh:nifty-tri": "node scripts/refresh-nifty-tri.js",
    "import:nifty-defaults": "node scripts/import-nifty-defaults.js",
    "import:absl-holdings": "node scripts/import-absl-holdings.js",
    "map:absl-portfolios": "node scripts/map-absl-portfolios.js",
    "import:amfi-aaum": "node scripts/import-amfi-aaum.js",
    "import:amfi-ter": "node scripts/import-amfi-ter.js",
    "backfill:amfi-aaum": "node scripts/import-amfi-aaum.js --all",
    "backfill:amfi-ter": "node scripts/import-amfi-ter.js --all",
    "backfill:amfi-history": "node scripts/backfill-amfi-history.js",
    "map:amfi-ter": "node scripts/map-amfi-ter.js"
